{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@personal-homepage-2024/assets": ["libs/assets/src/index.ts"],
      "@personal-homepage-2024/services": ["libs/services/src/index.ts"],
      "@personal-homepage-2024/types": ["libs/types/src/index.ts"],
      "@services": ["libs/services/src/index.ts"],
      "@types": ["libs/types/src/index.ts"],
      "@ui": ["libs/ui/src/index.ts"],
      "@assets": ["libs/assets/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
